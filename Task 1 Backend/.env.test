NODE_ENV=test
PORT=4000
API_BASE_PATH=/api/v1
NASA_API_KEY=test-key
NASA_API_BASE_URL=https://api.nasa.gov
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/space_explorer_test
REDIS_URL=redis://localhost:6379
CACHE_DRIVER=memory
CACHE_TTL_APOD=86400
CACHE_TTL_MARS_ROVER=3600
CACHE_TTL_NEO=3600
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
APOD_JOB_CRON=0 6 * * *
APOD_JOB_ENABLED=true
APOD_JOB_BACKFILL_ON_BOOT=false
LOG_LEVEL=error
CORS_ALLOWED_ORIGINS=*
